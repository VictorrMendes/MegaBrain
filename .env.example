# ──────────────────────────────────────────
# LLM
# ──────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
POSTGRES_DB=paios
POSTGRES_USER=paios
POSTGRES_PASSWORD=paios
DATABASE_URL=postgresql+asyncpg://paios:paios@postgres:5432/paios

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ──────────────────────────────────────────
# Notificações (ntfy já rodando no servidor)
# ──────────────────────────────────────────
NTFY_URL=http://192.168.1.26:2586
NTFY_TOPIC=paios

# ──────────────────────────────────────────
# Observabilidade (InfluxDB já rodando)
# ──────────────────────────────────────────
INFLUXDB_URL=http://192.168.1.26:8086
INFLUXDB_TOKEN=
INFLUXDB_ORG=vmserver
INFLUXDB_BUCKET=paios

# ──────────────────────────────────────────
# Auth
# ──────────────────────────────────────────
# Gerar com: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ──────────────────────────────────────────
# App
# ──────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO
API_PORT=8100
WEB_PORT=3100
